APP_NAME="PFA Sample Tracking"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://track.pfa.example

# Redirect http->https and send HSTS (see App\Http\Middleware\ForceHttps).
FORCE_HTTPS=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=warning
LOG_DEPRECATIONS_CHANNEL=null

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=pfa_sample_tracking
DB_USERNAME=
DB_PASSWORD=

# Session cookies only over HTTPS.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

QUEUE_CONNECTION=database
CACHE_STORE=file

# Comma-separated list of the panel / public domains allowed to call the API.
CORS_ALLOWED_ORIGINS=https://track.pfa.example

# SMS: default "log" until PFA's gateway is provided; then set SMS_DRIVER=sendpk.
SMS_DRIVER=log
# SENDPK_ENDPOINT=
# SENDPK_API_KEY=
# SENDPK_SENDER=PFA

MAIL_MAILER=log
